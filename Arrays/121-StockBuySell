#include<bits/stdc++.h>
using namespace std;

class Solution {
public:
    int maxProfit(vector<int>& prices) {
        int maxProfit=0;
        int n=prices.size();
        int profit;
        for(int i=0;i<n;i++){
            for(int j=i+1;j<n;j++){
                profit=prices[j]-prices[i];
                maxProfit=max(maxProfit,profit);
            }
        }
        return maxProfit;
    }
};